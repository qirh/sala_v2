{
  "name": "sala_v2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --threshold error",
    "lint": "npm run check",
    "test": "playwright test",
    "test:parity": "node scripts/parity_test.mjs",
    "test:visual": "VISUAL=1 playwright test tests/visual.spec.js",
    "test:visual:update": "VISUAL=1 PARITY_TARGET=prod playwright test tests/visual.spec.js --update-snapshots",
    "clean": "rm -rf node_modules/ build/ .svelte-kit/"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "svelte-i18n": "^4.0.1"
  },
  "prettier": {
    "tabWidth": 4,
    "singleQuote": true,
    "trailingComma": "all",
    "arrowParens": "always",
    "bracketSpacing": false
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 10"
  ],
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=20.19.0"
  },
  "overrides": {
    "fsevents": "^2.3.3",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.1",
    "sass": "^1.99.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "svelte-preprocess": "^6.0.3",
    "vite": "^8.0.10"
  }
}
